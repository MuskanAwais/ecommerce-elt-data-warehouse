# .gitignore for ecommerce-elt-data-warehouse

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
*.dist-info/
build/

# Virtual environments
.venv/
venv/
ENV/
env/
.env
.env.*

# Logs and pipeline results
results/**
!results/logs/
!results/logs/.gitkeep

# Jupyter notebooks
*.ipynb
.ipynb_checkpoints/

# DBT artifacts (legacy paths)
target/
dbt_packages/

# OS generated files
.DS_Store
Thumbs.db

# IDE / editor files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Miscellaneous
*.sqlite3
*.db
*.duckdb

# Generated raw data and local warehouse files
Data/raw/**/*
!Data/raw/.gitkeep
Data/processed/**/*
!Data/processed/.gitkeep
Data/warehouse/**/*
!Data/warehouse/.gitkeep

# Test cache
.pytest_cache/
config/.user.yml
